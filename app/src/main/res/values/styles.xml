<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Estilo para imágenes circulares -->
    <style name="CircularImageView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Estilo personalizado para RatingBar con tema de la app -->
    <style name="CustomRatingBar" parent="Widget.AppCompat.RatingBar.Small">
        <item name="colorControlNormal">?attr/colorOutline</item>
        <item name="colorControlActivated">?attr/colorPrimary</item>
    </style>

    <style name="SlayVault.PopupMenu" parent="Widget.Material3.PopupMenu">
        <item name="android:popupBackground">@color/white</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:itemTextAppearance">@style/SlayVault.PopupMenu.ItemText</item>
    </style>

    <style name="SlayVault.PopupMenu.ItemText" parent="@android:style/TextAppearance.Widget.IconMenu.Item">
        <item name="android:textColor">@color/black</item>
    </style>
</resources>
