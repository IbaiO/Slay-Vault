<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/queensListFragment">

    <!--
        Acciones globales: permiten navegar a los destinos raíz desde CUALQUIER fragmento.
        Esto es esencial para el Navigation Drawer: si el usuario está en el detalle y pulsa
        "Lista" en el drawer, la pila se limpia hasta queensListFragment sin duplicados.
    -->
    <action
        android:id="@+id/action_global_to_queensList"
        app:destination="@id/queensListFragment"
        app:popUpTo="@id/queensListFragment"
        app:popUpToInclusive="true"
        app:launchSingleTop="true"
        app:enterAnim="@anim/slide_in_left"
        app:exitAnim="@anim/slide_out_right" />

    <action
        android:id="@+id/action_global_to_settings"
        app:destination="@id/settingsFragment"
        app:popUpTo="@id/queensListFragment"
        app:popUpToInclusive="false"
        app:launchSingleTop="true"
        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />

    <action
        android:id="@+id/action_global_to_showTimer"
        app:destination="@id/showTimerFragment"
        app:popUpTo="@id/queensListFragment"
        app:popUpToInclusive="false"
        app:launchSingleTop="true"
        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />

    <action
        android:id="@+id/action_global_to_globalShout"
        app:destination="@id/gritoDiaFragment"
        app:popUpTo="@id/queensListFragment"
        app:popUpToInclusive="false"
        app:launchSingleTop="true"
        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />

    <!-- Fragment principal: Lista de Rivales -->
    <fragment
        android:id="@+id/queensListFragment"
        android:name="com.example.slay_vault.ui.fragments.QueensListFragment"
        android:label="SlayVault"
        tools:layout="@layout/fragment_queens_list">
        <action
            android:id="@+id/action_queensList_to_shadyDetails"
            app:destination="@id/shadyDetailsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_queensList_to_settings"
            app:destination="@id/settingsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- Fragment de detalles del shade -->
    <fragment
        android:id="@+id/shadyDetailsFragment"
        android:name="com.example.slay_vault.ui.fragments.ShadyDetailsFragment"
        android:label="@string/shade_details"
        tools:layout="@layout/fragment_shady_details">
        <argument
            android:name="shady_id"
            app:argType="string" />
        <action
            android:id="@+id/action_shadyDetails_to_queensList"
            app:destination="@id/queensListFragment"
            app:popUpTo="@id/queensListFragment"
            app:popUpToInclusive="false" />
    </fragment>

    <!-- Fragment de ajustes -->
    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.slay_vault.ui.fragments.SettingsFragment"
        android:label="@string/settings"
        tools:layout="@layout/fragment_settings">
        <action
            android:id="@+id/action_settings_to_queensList"
            app:destination="@id/queensListFragment"
            app:popUpTo="@id/queensListFragment"
            app:popUpToInclusive="false" />
    </fragment>

    <fragment
        android:id="@+id/showTimerFragment"
        android:name="com.example.slay_vault.ui.fragments.ShowTimerFragment"
        android:label="@string/show_timer"
        tools:layout="@layout/fragment_show_timer" />

    <fragment
        android:id="@+id/gritoDiaFragment"
        android:name="com.example.slay_vault.ui.fragments.GritoDiaFragment"
        android:label="@string/global_shout_title"
        tools:layout="@layout/fragment_global_shout" />

</navigation>

